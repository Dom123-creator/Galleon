# ===========================================
# Galleon Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
# Option 1: Neon (Recommended - Free tier available)
#   1. Go to https://neon.tech and create account
#   2. Create a new project
#   3. Copy the connection string
# Option 2: Supabase (Free tier available)
#   1. Go to https://supabase.com and create account
#   2. Create a new project
#   3. Go to Settings > Database > Connection string
# Option 3: Local PostgreSQL
#   postgresql://username:password@localhost:5432/galleon

DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# ===========================================
# ANTHROPIC / CLAUDE API (Required for AI agents)
# ===========================================
# 1. Go to https://console.anthropic.com
# 2. Create an API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# CLERK AUTHENTICATION (Required)
# ===========================================
# 1. Go to https://dashboard.clerk.com
# 2. Create a new application
# 3. Copy keys from API Keys section

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk URLs (these are correct as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret (for syncing users)
# 1. In Clerk Dashboard, go to Webhooks
# 2. Add endpoint: https://yourdomain.com/api/webhooks/clerk
# 3. Select events: user.created, user.updated, user.deleted
# 4. Copy the signing secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# STRIPE PAYMENTS (Required for subscriptions)
# ===========================================
# 1. Go to https://dashboard.stripe.com
# 2. Get API keys from Developers > API keys
# 3. Use test keys for development (start with pk_test_ and sk_test_)

STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret
# 1. Go to Developers > Webhooks
# 2. Add endpoint: https://yourdomain.com/api/webhooks/stripe
# 3. Select events: customer.subscription.*, invoice.payment_*
# 4. Copy the signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create products in Stripe Dashboard)
# 1. Go to Products > Add product
# 2. Create "Analyst" ($99/month), "Professional" ($499/month), and "Enterprise" (custom)
# 3. Copy the price IDs (start with price_)
STRIPE_ANALYST_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PROFESSIONAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_ANALYST_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# AWS S3 FILE STORAGE (Required for document uploads)
# ===========================================
# 1. Go to AWS Console > S3
# 2. Create a bucket (e.g., galleon-documents)
# 3. Create IAM user with S3 access
# 4. Copy credentials

AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=galleon-documents

# ===========================================
# EMAIL (Required for notifications)
# ===========================================
# 1. Go to https://resend.com
# 2. Create account and verify domain
# 3. Get API key from API Keys section

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Galleon <notifications@yourdomain.com>

# ===========================================
# APP CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# For production, change to your domain:
# NEXT_PUBLIC_APP_URL=https://galleon.ai

# ===========================================
# OPTIONAL: External Data Sources
# ===========================================
# PREQIN_API_KEY=
# SP_LCD_API_KEY=
# REDIS_URL=redis://localhost:6379
