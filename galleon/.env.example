# Database (Postgres optional — SQLite used by default)
DATABASE_URL=postgresql://postgres:password@localhost:5432/galleon

# Anthropic API Key (optional — enables AI assistant + LLM extraction)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# SEC EDGAR
EDGAR_USER_AGENT=Galleon Research contact@youremail.com

# API
API_HOST=0.0.0.0
API_PORT=8000

# Redis (for Celery task queue, optional)
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET=change-me-to-random-string

# Google OAuth (optional — enables "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Stripe (optional — enables seat-based billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_SUCCESS_URL=http://localhost:5173/?billing=success
STRIPE_CANCEL_URL=http://localhost:5173/?billing=cancel
